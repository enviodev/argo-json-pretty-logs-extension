{
    "name": "argo-json-pretty-logs-extension",
    "version": "0.1.0",
    "private": true,
    "description": "Chrome extension to pretty-print and colorize JSON logs in Argo CD UI",
    "license": "MIT",
    "scripts": {
        "build": "esbuild src/content.ts src/background.ts --bundle --outdir=public/dist --format=iife --target=chrome115 --minify",
        "dev": "esbuild src/content.ts src/background.ts --bundle --outdir=public/dist --format=iife --target=chrome115 --sourcemap --watch",
        "typecheck": "tsc --noEmit"
    },
    "devDependencies": {
        "esbuild": "^0.21.5",
        "typescript": "^5.6.2"
    }
}